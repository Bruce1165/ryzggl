    <wsdl:operation name="SaveApplySummary">
      <wsdl:documentation xmlns:wsdl="http://schemas.xmlsoap.org/wsdl/">增加一条企业申报数据的摘要，企业在第三方系统申报后，要调用此接口向办公大厅传入数据，此时状态一定要是9 待预约状态
                               如果ApplyCode(监察平台交易流水号)为空的话,表示增加一条数据摘要记录，如果不为空的表示插入 返回的是 ApplyCode 监察平台交易流水号
                                新建 0
                                正在编辑 1
                                编辑完成 2
                                待预约	9
                                窗口待递件	10
                                不予受理	-101
                                无效申报	-102
                                审查中	20
                                有时间限制审查，通过	30
                                有时间限制审查，不通过	31
                                有时间限制审查，其他	32
                                无时间限制审查，通过	40
                                办结通过 50
                                办结不通过 51
                                告知中	60
                                结果公示消息 70  
                                ApplyCode;//--监察平台的流水号
                                CountyCode;//由办公大厅分配的 网点编号
                                int ApplyStatus;//申报记录状态
                                string ApplyStatusDes;//状态描述
                                ApplyTitle;//申报的标题
                                ApplyExProperty;//申报记录的扩展属性描述 
                                LicenseCode;//申报事项的编码
                                ModifyUserName;//最后修改人的名称
                                </wsdl:documentation>
      <wsdl:input message="tns:SaveApplySummarySoapIn" />
      <wsdl:output message="tns:SaveApplySummarySoapOut" />
    </wsdl:operation>
