<w:sz-cs w:val="21"/></w:rPr><w:t>。</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:line="240" w:line-rule="auto"/><w:jc w:val="left"/><w:rPr><w:rFonts w:ascii="宋体" w:h-ansi="宋体" w:hint="fareast"/><wx:font wx:val="宋体"/><w:sz-cs w:val="21"/></w:rPr></w:pPr></w:p><w:p><w:pPr><w:spacing w:line="240" w:line-rule="auto"/><w:ind w:first-line-chars="1900"/><w:jc w:val="left"/><w:rPr><w:rFonts w:ascii="宋体" w:h-ansi="宋体" w:hint="fareast"/><wx:font wx:val="宋体"/><w:sz-cs w:val="21"/></w:rPr></w:pPr></w:p><w:p><w:pPr><w:spacing w:line="240" w:line-rule="auto"/><w:ind w:first-line-chars="1900"/><w:jc w:val="left"/><w:rPr><w:rFonts w:ascii="宋体" w:h-ansi="宋体"/><wx:font wx:val="宋体"/><w:sz-cs w:val="21"/></w:rPr></w:pPr><w:r><w:rPr><w:rFonts w:ascii="宋体" w:h-ansi="宋体" w:hint="fareast"/><wx:font wx:val="宋体"/><w:sz-cs w:val="21"/></w:rPr><w:t>（企业公章）：          年    月    日</w:t></w:r></w:p></w:tc></w:tr></w:tbl><w:p><w:pPr><w:jc w:val="center"/><w:rPr><w:sz-cs w:val="21"/></w:rPr></w:pPr><w:r><w:rPr><w:rFonts w:ascii="宋体" w:h-ansi="宋体" w:hint="fareast"/><wx:font wx:val="宋体"/><w:sz-cs w:val="21"/></w:rPr><w:t>备注：</w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="宋体" w:h-ansi="宋体"/><wx:font wx:val="宋体"/><w:sz-cs w:val="21"/></w:rPr><w:t>申请人网上申请并上传扫描件</w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="宋体" w:h-ansi="宋体" w:hint="fareast"/><wx:font wx:val="宋体"/><w:sz-cs w:val="21"/></w:rPr><w:t>提交企业确认</w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="宋体" w:h-ansi="宋体"/><wx:font wx:val="宋体"/><w:sz-cs w:val="21"/></w:rPr><w:t>-企业网上确认-住建委网上</w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="宋体" w:h-ansi="宋体" w:hint="fareast"/><wx:font wx:val="宋体"/><w:sz-cs w:val="21"/></w:rPr><w:t>审批</w:t></w:r></w:p><w:p><w:pPr><w:snapToGrid w:val="off"/><w:spacing w:line="288" w:line-rule="auto"/><w:rPr><w:rFonts w:ascii="宋体" w:h-ansi="宋体"/><wx:font wx:val="宋体"/><w:sz-cs w:val="21"/></w:rPr></w:pPr></w:p><w:sectPr><w:pgSz w:w="11907" w:h="16840"/><w:pgMar w:top="1304" w:right="1077" w:bottom="851" w:left="1077" w:header="851" w:footer="992" w:gutter