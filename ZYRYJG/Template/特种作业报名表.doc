pToGrid w:val="off"/><w:sz-cs w:val="21"/></w:rPr><w:t>二、本人在本次申报时提交的所有信息均真实、合法、有效，未隐瞒有关人员禁止行为的信息，</w:t></w:r><w:r wsp:rsidRPr="001307F2"><w:rPr><w:rFonts w:ascii="宋体" w:h-ansi="宋体" w:hint="fareast"/><wx:font wx:val="宋体"/><w:sz-cs w:val="21"/></w:rPr><w:t>如有虚假愿承担由此产生的一切法律后果。</w:t></w:r></w:p><w:p wsp:rsidR="009949E3" wsp:rsidRPr="001307F2" wsp:rsidRDefault="009949E3" wsp:rsidP="009949E3"><w:pPr><w:spacing w:line="300" w:line-rule="auto"/><w:ind w:first-line-chars="300" w:first-line="630"/><w:jc w:val="left"/><w:rPr><w:rFonts w:ascii="宋体" w:h-ansi="宋体"/><wx:font wx:val="宋体"/><w:snapToGrid w:val="off"/><w:sz-cs w:val="21"/></w:rPr></w:pPr><w:r wsp:rsidRPr="001307F2"><w:rPr><w:rFonts w:ascii="宋体" w:h-ansi="宋体" w:hint="fareast"/><wx:font wx:val="宋体"/><w:sz-cs w:val="21"/></w:rPr><w:t>申请人（签字）：                                       年     月     日</w:t></w:r></w:p></w:tc></w:tr><w:tr wsp:rsidR="000059DB" wsp:rsidRPr="00D14530" wsp:rsidTr="000059DB"><w:tblPrEx><w:tblBorders><w:top w:val="single" w:sz="12" wx:bdrwidth="30" w:space="0" w:color="auto"/><w:left w:val="single" w:sz="12" wx:bdrwidth="30" w:space="0" w:color="auto"/><w:bottom w:val="single" w:sz="12" wx:bdrwidth="30" w:space="0" w:color="auto"/><w:right w:val="single" w:sz="12" wx:bdrwidth="30" w:space="0" w:color="auto"/><w:insideH w:val="single" w:sz="6" wx:bdrwidth="15" w:space="0" w:color="auto"/><w:insideV w:val="single" w:sz="6" wx:bdrwidth="15" w:space="0" w:color="auto"/></w:tblBorders></w:tblPrEx><w:trPr><w:trHeight w:val="1807"/></w:trPr><w:tc><w:tcPr><w:tcW w:w="748" w:type="dxa"/><w:tcBorders><w:left w:val="single" w:sz="4" wx:bdrwidth="10" w:space="0" w:color="auto"/></w:tcBorders></w:tcPr><w:p wsp:rsidR="000059DB" wsp:rsidRDefault="000059DB" wsp:rsidP="000059DB"><w:pPr><w:jc w:val="center"/><w:rPr><w:rFonts w:ascii="宋体" w:h-ansi="宋体"/><wx:font wx:val="宋体"/><w:sz-cs w:val="21"/></w:rPr></w:pPr><w:r><w:rPr><w:rFonts w:ascii="宋体" w:h-ansi="宋体" w:hint="fareast"/><wx:font wx:val="宋体"/><w:sz-cs w:val="21"/><